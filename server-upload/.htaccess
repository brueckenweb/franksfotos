# FranksFotos – pics.frank-sellke.de Webroot
# Diese .htaccess in den Webroot von pics.frank-sellke.de hochladen

# ==============================================================
# MIME-TYPEN (wichtig für Browser-Videoabspieler)
# ==============================================================
AddType video/mp4         .mp4 .m4v
AddType video/quicktime   .mov
AddType video/webm        .webm
AddType video/x-msvideo   .avi
AddType video/x-matroska  .mkv
AddType image/jpeg        .jpg .jpeg
AddType image/png         .png
AddType image/webp        .webp

# ==============================================================
# SICHERHEIT: Direkten Zugriff auf PHP-Dateien einschränken
# ==============================================================

# Nur upload.php ist von außen erreichbar
# Alle anderen PHP-Dateien werden geblockt
<FilesMatch "\.php$">
    Order Deny,Allow
    Deny from all
</FilesMatch>

<Files "upload.php">
    Order Allow,Deny
    Allow from all
</Files>

# ==============================================================
# MEDIENDATEIEN: Caching für Bilder/Videos
# ==============================================================
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg  "access plus 1 year"
    ExpiresByType image/png   "access plus 1 year"
    ExpiresByType image/webp  "access plus 1 year"
    ExpiresByType video/mp4   "access plus 1 year"
</IfModule>

# ==============================================================
# CORS: Bilder/Videos öffentlich zugänglich (frank-sellke.de)
# ==============================================================
<IfModule mod_headers.c>
    <FilesMatch "\.(jpg|jpeg|png|webp|gif|mp4|mov|webm|mkv|avi)$">
        Header always set Access-Control-Allow-Origin "*"
    </FilesMatch>
</IfModule>

# ==============================================================
# DIRECTORY LISTING deaktivieren
# ==============================================================
Options -Indexes
