# Reverse Proxy für Next.js (Port 3001)
# Diese Datei wird automatisch per GitHub Actions deployt

Options -MultiViews -Indexes
RewriteEngine On

# WebSocket-Verbindungen proxyen
RewriteCond %{HTTP:Upgrade} websocket [NC]
RewriteCond %{HTTP:Connection} upgrade [NC]
RewriteRule ^(.*)$ ws://127.0.0.1:3001/$1 [P,L]

# Root-Pfad explizit behandeln (leerer Pfad nach DocumentRoot)
RewriteRule ^$ http://127.0.0.1:3001/ [P,L]

# Alle anderen Pfade zu Next.js proxyen
RewriteRule ^(.+)$ http://127.0.0.1:3001/$1 [P,L]
