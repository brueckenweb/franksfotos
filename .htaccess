# Reverse Proxy für Next.js (Port 3001)
# Diese Datei wird automatisch per GitHub Actions deployt

Options -MultiViews -Indexes

# Kein Body-Size-Limit für Apache-Proxy (Fotos/Videos können > 100 MB sein)
# Standard-Apache-Limit wäre sonst 0 (vom Server gesetzt) → Uploads schlagen fehl
LimitRequestBody 524288000

# DirectoryIndex deaktivieren – verhindert, dass Apache / zu /index.html umschreibt
# BEVOR die RewriteRules laufen (was zu 404 in Next.js führen würde)
DirectoryIndex disabled

RewriteEngine On

# WebSocket-Verbindungen proxyen
RewriteCond %{HTTP:Upgrade} websocket [NC]
RewriteCond %{HTTP:Connection} upgrade [NC]
RewriteRule ^(.*)$ ws://127.0.0.1:3001/$1 [P,L]

# Root-Pfad explizit behandeln (leerer Pfad nach DocumentRoot)
RewriteRule ^$ http://127.0.0.1:3001/ [P,L]

# Falls Apache /index.html intern anfügt, auch das als / proxyen
RewriteRule ^index\.html$ http://127.0.0.1:3001/ [P,L]

# Alle anderen Pfade zu Next.js proxyen
RewriteRule ^(.+)$ http://127.0.0.1:3001/$1 [P,L]
